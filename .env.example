# ─────────────────────────────────────────────────────────────────────────────
# UAV — URL Auto Visitor Bot (by sonic)
# Copy to `.env` and fill in real values. NEVER commit `.env` to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram (REQUIRED) ──────────────────────────────────────────────────────
# Get from @BotFather. Bot will not start without this.
BOT_TOKEN=123456:ABCDEF_replace_me

# Your numeric Telegram user ID. Used for online/offline alerts.
# Get from @userinfobot. Optional but recommended.
OWNER_ID=

# ── Access Control (HIGHLY RECOMMENDED) ──────────────────────────────────────
# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow ALL users (open bot — DoS risk).
# Example: ALLOWED_USERS=123456789,987654321
ALLOWED_USERS=

# ── Browser Paths (auto-detected if blank) ───────────────────────────────────
# Override only if auto-detection fails. Leave empty on production EC2.
CHROMIUM_PATH=
CHROMEDRIVER_PATH=

# ── keep_alive / self-pinger ─────────────────────────────────────────────────
# Set to "false" on EC2 (default). Only set "true" for Replit free tier.
SELF_PING_ENABLED=false

# ── Deploy script (deploy.py) ────────────────────────────────────────────────
# GitHub push (Personal Access Token with repo scope)
GITHUB_TOKEN=

# Production EC2 server
EC2_HOST=138.128.243.189
EC2_USER=root
EC2_DEPLOY_PATH=/root/Auto-TGBot-Clicker
EC2_SERVICE=visitor-bot

# Auth — choose ONE:
#   (a) password auth via sshpass:
EC2_SSH_PASSWORD=
#   (b) key auth (path to .pem or .ppk):
EC2_SSH_KEY_PATH=
